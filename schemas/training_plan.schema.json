{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://running-coach.local/schemas/training_plan.schema.json",
  "title": "TrainingPlan",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "week_start": { "type": "string", "format": "date" },
    "week_end": { "type": "string", "format": "date" },
    "generated_at": { "type": "string", "format": "date-time" },
    "summary": { "type": "string" },
    "days": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "date": { "type": "string", "format": "date" },
          "type": {
            "type": "string",
            "enum": [
              "rest",
              "easy_run",
              "long_run",
              "intervals",
              "tempo",
              "recovery",
              "strength",
              "cross_training"
            ]
          },
          "duration_min": { "type": ["integer", "null"], "minimum": 0 },
          "distance_km": { "type": ["number", "null"], "minimum": 0 },
          "target_hr_min": { "type": ["integer", "null"], "minimum": 20, "maximum": 240 },
          "target_hr_max": { "type": ["integer", "null"], "minimum": 20, "maximum": 240 },
          "target_pace_min_sec_per_km": { "type": ["integer", "null"], "minimum": 0 },
          "target_pace_max_sec_per_km": { "type": ["integer", "null"], "minimum": 0 },
          "instructions": { "type": "string" },
          "warnings": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": [
          "date",
          "type",
          "duration_min",
          "distance_km",
          "target_hr_min",
          "target_hr_max",
          "target_pace_min_sec_per_km",
          "target_pace_max_sec_per_km",
          "instructions",
          "warnings"
        ]
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["week_start", "week_end", "generated_at", "summary", "days", "warnings"]
}
