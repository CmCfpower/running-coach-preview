{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://running-coach.local/schemas/workout.schema.json",
  "title": "Workout",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "date": { "type": "string", "format": "date" },
    "source": { "type": "string" },
    "raw_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "raw_file_hashes": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "sport": {
      "type": "string",
      "enum": ["running", "walking", "cycling", "swimming", "strength", "cross_training", "unknown"]
    },
    "distance_km": { "type": ["number", "null"], "minimum": 0 },
    "duration_sec": { "type": ["integer", "null"], "minimum": 0 },
    "avg_pace_sec_per_km": { "type": ["integer", "null"], "minimum": 0 },
    "avg_hr": { "type": ["integer", "null"], "minimum": 20, "maximum": 240 },
    "max_hr": { "type": ["integer", "null"], "minimum": 20, "maximum": 250 },
    "elevation_gain_m": { "type": ["number", "null"] },
    "cadence_spm": { "type": ["integer", "null"], "minimum": 0, "maximum": 260 },
    "rpe": { "type": ["number", "null"], "minimum": 1, "maximum": 10 },
    "extraction_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": [
    "id",
    "date",
    "source",
    "raw_files",
    "sport",
    "distance_km",
    "duration_sec",
    "avg_pace_sec_per_km",
    "avg_hr",
    "max_hr",
    "elevation_gain_m",
    "cadence_spm",
    "rpe",
    "extraction_confidence",
    "notes"
  ]
}
